# Copy this file to .env and fill in your credentials.
# .env is gitignored and will never be committed.

# NVIDIA NIM API Key (required for Stage 9 LLM)
# Obtain from: https://build.nvidia.com/
NVIDIA_API_KEY=your_nvidia_api_key_here

# ESP32 bridge network address (changes with Wi-Fi / phone hotspot).
# Optional — falls back to the defaults below if unset.
ESP32_HOST=172.20.10.3
AUD1_PORT=5001
PCM1_PORT=5000
